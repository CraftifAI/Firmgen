{
  "schema_version": "1.1",
  "board_id": "esp32-h2-devkitm-1",
  "board_version": "1.0.0",
  "name": "ESP32-H2-DevKitM-1",
  "variant": "MINI-1",
  "description": "Espressif ESP32-H2-DevKitM-1 (ESP32-H2-MINI-1, 4MB flash, no PSRAM). RISC-V single-core with BLE 5.3 and 802.15.4 (Thread/Zigbee). No Wi-Fi.",

  "chip": {
    "type": "esp32h2",
    "min_revision": 0
  },

  "identification": {
    "chip_type": "esp32h2",
    "flash_size_range": ["4MB"],
    "psram_present": false,
    "psram_size": null,
    "flash_manufacturer_ids": [],
    "flash_device_ids": []
  },

  "hardware": {
    "flash": {
      "size": "4MB",
      "size_config": "CONFIG_ESPTOOLPY_FLASHSIZE_4MB",
      "mode": "qio",
      "mode_config": "CONFIG_ESPTOOLPY_FLASHMODE_QIO",
      "freq": "48m",
      "freq_config": "CONFIG_ESPTOOLPY_FLASHFREQ_48M",
      "notes": "ESP32-H2 flash typically runs at 48MHz."
    },
    "psram": {
      "enabled": false,
      "size": "",
      "type": "",
      "mode": "",
      "mode_config": null
    },
    "uart_console": {
      "tx": 24,
      "rx": 23,
      "uart": "uart0",
      "notes": "ESP32-H2 default UART0 pins."
    },
    "usb_jtag": {
      "supported": true,
      "d_minus": 26,
      "d_plus": 27,
      "notes": "Built-in USB Serial/JTAG controller."
    }
  },

  "gpio": {
    "led": {
      "pin": 8,
      "type": "ws2812",
      "driver": "led_strip",
      "notes": "On-board RGB LED on GPIO8 (DevKitM-1 schematic)."
    },
    "button": {
      "pin": 9,
      "type": "boot",
      "pull": "up",
      "notes": "BOOT button on GPIO9."
    },

    "safe_pins": [0, 1, 2, 3, 4, 5, 8, 10, 11, 12, 13, 14, 22, 25],
    "restricted_pins": [6, 7, 15, 16, 17, 18, 19, 20, 21],
    "restricted_reasons": {
      "15-21": "Connected to integrated SPI flash on ESP32-H2-MINI-1; not usable as GPIO.",
      "6-7": "Reserved for 32.768 kHz crystal on some carriers."
    }
  },

  "pwm": {
    "defaults": {
      "pin": 8,
      "timer": 0,
      "channel": 0,
      "freq_hz": 5000,
      "duty_resolution": 13,
      "notes": "Generic LEDC default; GPIO8 also drives the on-board RGB LED."
    },
    "alternate_pins": [0, 1, 2, 3, 4, 5, 10, 11, 12, 13, 14, 22, 25]
  },

  "adc": {
    "defaults": {
      "pin": 1,
      "channel": "ADC1_CH0",
      "attenuation": "11dB",
      "width": 12,
      "notes": "ESP32-H2 ADC1_CH0 is GPIO1."
    },
    "adc1_pins": [1, 2, 3, 4, 5],
    "adc2_pins": [],
    "notes": "ESP32-H2 has only ADC1 (5 channels)."
  },

  "wifi": {
    "station": {
      "sdkconfig": {},
      "notes": "ESP32-H2 has no Wi-Fi. Use BLE/Thread/Zigbee for connectivity."
    }
  },

  "config_presets": {
    "default": {
      "description": "Standard configuration for ESP32-H2-DevKitM-1",
      "tags": ["standard", "general"],
      "use_cases": ["general development", "prototyping"],
      "sdkconfig": {
        "CONFIG_IDF_TARGET": "esp32h2",
        "CONFIG_ESPTOOLPY_FLASHSIZE_4MB": "y",
        "CONFIG_ESPTOOLPY_FLASHMODE_QIO": "y",
        "CONFIG_ESPTOOLPY_FLASHFREQ_48M": "y",
        "CONFIG_SPIRAM": "n"
      }
    },
    "thread": {
      "extends": "default",
      "description": "OpenThread (802.15.4) end device",
      "tags": ["thread", "ot", "matter"],
      "use_cases": ["Thread mesh networking", "Matter over Thread"],
      "sdkconfig": {
        "CONFIG_OPENTHREAD_ENABLED": "y",
        "CONFIG_IEEE802154_ENABLED": "y"
      }
    },
    "zigbee": {
      "extends": "default",
      "description": "Zigbee end device",
      "tags": ["zigbee", "802.15.4"],
      "use_cases": ["Zigbee mesh networking"],
      "sdkconfig": {
        "CONFIG_IEEE802154_ENABLED": "y",
        "CONFIG_ZB_ENABLED": "y"
      }
    },
    "ble": {
      "extends": "default",
      "description": "Bluetooth LE 5.3",
      "tags": ["ble", "bluetooth"],
      "use_cases": ["BLE peripheral or central applications"],
      "sdkconfig": {
        "CONFIG_BT_ENABLED": "y",
        "CONFIG_BT_BLE_ENABLED": "y"
      }
    }
  },

  "required_components": [],
  "conflicting_components": [],
  "recommended_components": ["led_strip", "esp-zboss-lib", "esp-zigbee-lib"],

  "kb": {
    "collection": "esp32-h2-devkitm-1",
    "pinout_doc": "01_board_docs/pinout_reference.md",
    "board_summary_doc": "01_board_docs/board_summary.md",
    "gpio_table_doc": "01_board_docs/gpio_pinout_esp32h2.inc",
    "kconfig_symbols": "04_kconfig_symbols/config_symbols.jsonl"
  },

  "documentation": {
    "datasheet": "https://www.espressif.com/sites/default/files/documentation/esp32-h2_datasheet_en.pdf",
    "modules_overview": "https://www.espressif.com/en/products/devkits/esp32-h2-devkitm-1"
  }
}
