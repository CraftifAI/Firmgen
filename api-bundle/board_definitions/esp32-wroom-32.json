{
  "schema_version": "1.1",
  "board_id": "esp32-wroom-32",
  "board_version": "1.0.0",
  "name": "ESP32-WROOM-32",
  "variant": "4MB",
  "description": "ESP32-WROOM-32 module with integrated 4MB SPI flash (no PSRAM). Note: LED/button pins depend on the carrier/dev board.",

  "chip": {
    "type": "esp32",
    "min_revision": 0
  },

  "identification": {
    "chip_type": "esp32",
    "flash_size_range": ["4MB"],
    "psram_present": false,
    "psram_size": null,
    "flash_manufacturer_ids": [],
    "flash_device_ids": []
  },

  "hardware": {
    "flash": {
      "size": "4MB",
      "size_config": "CONFIG_ESPTOOLPY_FLASHSIZE_4MB",
      "mode": "dio",
      "mode_config": "CONFIG_ESPTOOLPY_FLASHMODE_DIO",
      "freq": "40m",
      "freq_config": "CONFIG_ESPTOOLPY_FLASHFREQ_40M",
      "notes": "Many ESP32 designs use 40MHz flash. Mode/freq can be adjusted per board/flash stability."
    },
    "psram": {
      "enabled": false,
      "size": "",
      "type": "",
      "mode": "",
      "mode_config": null
    },
    "uart_console": {
      "tx": 1,
      "rx": 3,
      "uart": "uart0",
      "notes": "Default ESP32 UART0 is typically GPIO1 (TX0) and GPIO3 (RX0)."
    },
    "usb_jtag": {
      "supported": false,
      "d_minus": null,
      "d_plus": null
    }
  },

  "gpio": {
    "led": {
      "pin": 2,
      "type": "none",
      "driver": null,
      "notes": "ESP32-WROOM-32 is a module; any LED is on the dev board/carrier (pin depends on that board)."
    },
    "button": {
      "pin": 0,
      "type": "none",
      "pull": null,
      "notes": "Module has no buttons; BOOT/EN exist on dev boards."
    },

    "safe_pins": [
      2, 4, 5, 12, 13, 14, 15, 16, 17, 18, 19, 21, 22, 23, 25, 26, 27, 32, 33
    ],
    "restricted_pins": [6, 7, 8, 9, 10, 11],
    "restricted_reasons": {
      "6-11": "Connected to integrated SPI flash on ESP32-WROOM-32; cannot be used as normal GPIO."
    }
  },

  "pwm": {
    "defaults": {
      "pin": 2,
      "timer": 0,
      "channel": 0,
      "freq_hz": 5000,
      "duty_resolution": 13,
      "notes": "Generic LEDC default; choose a pin actually routed on your carrier board."
    },
    "alternate_pins": [4, 5, 12, 13, 14, 15, 16, 17, 18, 19, 21, 22, 23, 25, 26, 27, 32, 33]
  },

  "adc": {
    "defaults": {
      "pin": 36,
      "channel": "ADC1_CH0",
      "attenuation": "11dB",
      "width": 12,
      "notes": "ESP32 ADC1_CH0 is GPIO36 (SVP). Availability depends on carrier routing."
    },
    "adc1_pins": [32, 33, 34, 35, 36, 37, 38, 39],
    "adc2_pins": [0, 2, 4, 12, 13, 14, 15, 25, 26, 27],
    "notes": "ADC2 may conflict with Wi-Fi usage."
  },

  "wifi": {
    "station": {
      "sdkconfig": {
        "CONFIG_ESP_WIFI_ENABLED": "y",
        "CONFIG_ESP_WIFI_STA_ENABLE": "y",
        "CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM": "10",
        "CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM": "32",
        "CONFIG_ESP_WIFI_TX_BUFFER_TYPE": "1",
        "CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM": "32"
      }
    }
  },

  "config_presets": {
    "default": {
      "description": "Standard configuration for ESP32-WROOM-32",
      "tags": ["standard", "general"],
      "use_cases": ["general development", "prototyping"],
      "sdkconfig": {
        "CONFIG_IDF_TARGET": "esp32",
        "CONFIG_ESPTOOLPY_FLASHSIZE_4MB": "y",
        "CONFIG_ESPTOOLPY_FLASHMODE_DIO": "y",
        "CONFIG_ESPTOOLPY_FLASHFREQ_40M": "y",
        "CONFIG_SPIRAM": "n"
      }
    },
    "wifi_station": {
      "extends": "default",
      "description": "WiFi Station mode configuration",
      "tags": ["wifi", "station"],
      "use_cases": ["WiFi client applications"],
      "sdkconfig": {
        "CONFIG_ESP_WIFI_ENABLED": "y",
        "CONFIG_ESP_WIFI_STA_ENABLE": "y"
      }
    }
  },

  "required_components": [],
  "conflicting_components": [],
  "recommended_components": [],

  "kb": {
    "collection": "esp32-wroom-32",
    "pinout_doc": "01_board_docs/pinout_reference.md",
    "board_summary_doc": "01_board_docs/board_summary.md",
    "gpio_table_doc": "01_board_docs/gpio_pinout_esp32.inc",
    "kconfig_symbols": "04_kconfig_symbols/config_symbols.jsonl"
  },

  "documentation": {
    "datasheet": "https://www.espressif.com/sites/default/files/documentation/esp32-wroom-32_datasheet_en.pdf",
    "modules_overview": "https://www.espressif.com/en/products/modules"
  }
}

